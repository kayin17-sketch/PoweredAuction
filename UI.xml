<Ui xmlns="http://www.blizzard.com/wow/ui/"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.blizzard.com/wow/ui/">

    <Frame name="PoweredAuctionFrame" toplevel="true" frameStrata="DIALOG"
           movable="true" enableMouse="true" hidden="true" parent="UIParent">
        <Size>
            <AbsDimension x="520" y="520"/>
        </Size>
        <Anchors>
            <Anchor point="CENTER"/>
        </Anchors>

        <Backdrop bgFile="Interface\Buttons\WHITE8X8"
                  edgeFile="Interface\Buttons\WHITE8X8"
                  tile="true">
            <BackgroundInsets>
                <AbsInset left="1" right="1" top="1" bottom="1"/>
            </BackgroundInsets>
            <TileSize>
                <AbsValue val="32"/>
            </TileSize>
            <EdgeSize>
                <AbsValue val="1"/>
            </EdgeSize>
            <Color r="0.07" g="0.07" b="0.07" a="0.93"/>
            <BorderColor r="0.12" g="0.12" b="0.12" a="1"/>
        </Backdrop>

        <Layers>
            <Layer level="ARTWORK">
                <Texture name="$parentHeaderBg">
                    <Size>
                        <AbsDimension x="518" y="30"/>
                    </Size>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
                            <Offset>
                                <AbsDimension x="1" y="-1"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.16" g="0.18" b="0.22" a="0.9"/>
                </Texture>

                <FontString name="$parentTitle" inherits="GameFontNormal" text="PoweredAuction">
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parentHeaderBg" relativePoint="LEFT">
                            <Offset>
                                <AbsDimension x="10" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.84" g="0.88" b="0.83" a="1"/>
                </FontString>

                <Texture name="$parentToolbarBg">
                    <Size>
                        <AbsDimension x="518" y="36"/>
                    </Size>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
                            <Offset>
                                <AbsDimension x="1" y="-31"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.12" g="0.12" b="0.12" a="1"/>
                </Texture>

                <Texture name="$parentListHeaderBg">
                    <Size>
                        <AbsDimension x="448" y="20"/>
                    </Size>
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
                            <Offset>
                                <AbsDimension x="10" y="-72"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.11" g="0.11" b="0.11" a="1"/>
                </Texture>

                <FontString name="$parentColName" inherits="GameFontNormalSmall" text="Item">
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parentListHeaderBg" relativePoint="LEFT">
                            <Offset>
                                <AbsDimension x="5" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.6" g="0.6" b="0.6" a="1"/>
                </FontString>

                <FontString name="$parentColPrice" inherits="GameFontNormalSmall" text="Price">
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parentListHeaderBg" relativePoint="LEFT">
                            <Offset>
                                <AbsDimension x="280" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.6" g="0.6" b="0.6" a="1"/>
                </FontString>

                <FontString name="$parentColQty" inherits="GameFontNormalSmall" text="Total">
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parentListHeaderBg" relativePoint="LEFT">
                            <Offset>
                                <AbsDimension x="370" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.6" g="0.6" b="0.6" a="1"/>
                </FontString>

                <FontString name="$parentColScans" inherits="GameFontNormalSmall" text="Scans">
                    <Anchors>
                        <Anchor point="RIGHT" relativeTo="$parentListHeaderBg" relativePoint="RIGHT">
                            <Offset>
                                <AbsDimension x="-5" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.6" g="0.6" b="0.6" a="1"/>
                </FontString>

                <Texture name="$parentStatusBarBg">
                    <Size>
                        <AbsDimension x="518" y="24"/>
                    </Size>
                    <Anchors>
                        <Anchor point="BOTTOMLEFT" relativeTo="$parent" relativePoint="BOTTOMLEFT">
                            <Offset>
                                <AbsDimension x="1" y="1"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.16" g="0.18" b="0.22" a="0.9"/>
                </Texture>

                <FontString name="$parentStatusLabel" inherits="GameFontNormalSmall" text="Ready">
                    <Anchors>
                        <Anchor point="LEFT" relativeTo="$parentStatusBarBg" relativePoint="LEFT">
                            <Offset>
                                <AbsDimension x="10" y="0"/>
                            </Offset>
                        </Anchor>
                    </Anchors>
                    <Color r="0.84" g="0.88" b="0.83" a="1"/>
                </FontString>
            </Layer>
        </Layers>

        <Frames>
            <Button name="$parentCloseButton" inherits="UIPanelCloseButton">
                <Anchors>
                    <Anchor point="TOPRIGHT" relativeTo="$parent" relativePoint="TOPRIGHT">
                        <Offset>
                            <AbsDimension x="2" y="2"/>
                        </Offset>
                    </Anchor>
                </Anchors>
            </Button>

            <EditBox name="$parentItemInput" autoFocus="false" letters="60">
                <Size>
                    <AbsDimension x="280" y="24"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="$parentToolbarBg" relativePoint="TOPLEFT">
                        <Offset>
                            <AbsDimension x="10" y="-6"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Backdrop bgFile="Interface\Buttons\WHITE8X8"
                          edgeFile="Interface\Buttons\WHITE8X8"
                          tile="true">
                    <BackgroundInsets>
                        <AbsInset left="1" right="1" top="1" bottom="1"/>
                    </BackgroundInsets>
                    <EdgeSize>
                        <AbsValue val="1"/>
                    </EdgeSize>
                    <Color r="0.16" g="0.16" b="0.16" a="1"/>
                    <BorderColor r="0.25" g="0.25" b="0.25" a="1"/>
                </Backdrop>
                <FontString inherits="GameFontHighlight" justifyH="LEFT"/>
                <Scripts>
                    <OnEnterPressed>
                        PoweredAuction_UIAddItem()
                    </OnEnterPressed>
                    <OnEscapePressed>
                        this:ClearFocus()
                    </OnEscapePressed>
                    <OnReceiveDrag>
                        PoweredAuction_OnReceiveDrag()
                    </OnReceiveDrag>
                    <OnTextChanged>
                        PoweredAuction_OnInputTextChanged()
                    </OnTextChanged>
                </Scripts>
            </EditBox>

            <Button name="$parentAddButton" text="Add">
                <Size>
                    <AbsDimension x="70" y="22"/>
                </Size>
                <Anchors>
                    <Anchor point="LEFT" relativeTo="$parentItemInput" relativePoint="RIGHT">
                        <Offset>
                            <AbsDimension x="4" y="0"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Backdrop bgFile="Interface\Buttons\WHITE8X8"
                          edgeFile="Interface\Buttons\WHITE8X8"
                          tile="true">
                    <BackgroundInsets>
                        <AbsInset left="1" right="1" top="1" bottom="1"/>
                    </BackgroundInsets>
                    <EdgeSize>
                        <AbsValue val="1"/>
                    </EdgeSize>
                    <Color r="0.19" g="0.22" b="0.33" a="0.9"/>
                    <BorderColor r="0.3" g="0.3" b="0.4" a="1"/>
                </Backdrop>
                <NormalFont style="GameFontNormal"/>
                <HighlightFont style="GameFontHighlight"/>
                <Scripts>
                    <OnClick>
                        PoweredAuction_UIAddItem()
                    </OnClick>
                    <OnEnter>
                        this:SetBackdropColor(0.25, 0.28, 0.4, 0.95)
                    </OnEnter>
                    <OnLeave>
                        this:SetBackdropColor(0.19, 0.22, 0.33, 0.9)
                    </OnLeave>
                </Scripts>
            </Button>

            <Button name="$parentScanButton" text="Scan">
                <Size>
                    <AbsDimension x="70" y="22"/>
                </Size>
                <Anchors>
                    <Anchor point="LEFT" relativeTo="$parentAddButton" relativePoint="RIGHT">
                        <Offset>
                            <AbsDimension x="4" y="0"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Backdrop bgFile="Interface\Buttons\WHITE8X8"
                          edgeFile="Interface\Buttons\WHITE8X8"
                          tile="true">
                    <BackgroundInsets>
                        <AbsInset left="1" right="1" top="1" bottom="1"/>
                    </BackgroundInsets>
                    <EdgeSize>
                        <AbsValue val="1"/>
                    </EdgeSize>
                    <Color r="0.15" g="0.35" b="0.15" a="0.9"/>
                    <BorderColor r="0.2" g="0.45" b="0.2" a="1"/>
                </Backdrop>
                <NormalFont style="GameFontNormal"/>
                <HighlightFont style="GameFontHighlight"/>
                <Scripts>
                    <OnClick>
                        if not PoweredAuction_StartScan then return end
                        PoweredAuction_StartScan()
                    </OnClick>
                    <OnEnter>
                        this:SetBackdropColor(0.2, 0.45, 0.2, 0.95)
                    </OnEnter>
                    <OnLeave>
                        this:SetBackdropColor(0.15, 0.35, 0.15, 0.9)
                    </OnLeave>
                </Scripts>
            </Button>

            <Button name="$parentRemoveButton" text="Remove">
                <Size>
                    <AbsDimension x="70" y="22"/>
                </Size>
                <Anchors>
                    <Anchor point="LEFT" relativeTo="$parentScanButton" relativePoint="RIGHT">
                        <Offset>
                            <AbsDimension x="4" y="0"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Backdrop bgFile="Interface\Buttons\WHITE8X8"
                          edgeFile="Interface\Buttons\WHITE8X8"
                          tile="true">
                    <BackgroundInsets>
                        <AbsInset left="1" right="1" top="1" bottom="1"/>
                    </BackgroundInsets>
                    <EdgeSize>
                        <AbsValue val="1"/>
                    </EdgeSize>
                    <Color r="0.4" g="0.13" b="0.13" a="0.9"/>
                    <BorderColor r="0.55" g="0.18" b="0.18" a="1"/>
                </Backdrop>
                <NormalFont style="GameFontNormal"/>
                <HighlightFont style="GameFontHighlight"/>
                <Scripts>
                    <OnClick>
                        PoweredAuction_UIRemoveSelected()
                    </OnClick>
                    <OnEnter>
                        this:SetBackdropColor(0.55, 0.18, 0.18, 0.95)
                    </OnEnter>
                    <OnLeave>
                        this:SetBackdropColor(0.4, 0.13, 0.13, 0.9)
                    </OnLeave>
                </Scripts>
            </Button>

            <ScrollFrame name="$parentItemListScrollFrame" inherits="FauxScrollFrameTemplate">
                <Size>
                    <AbsDimension x="470" y="370"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
                        <Offset>
                            <AbsDimension x="10" y="-93"/>
                        </Offset>
                    </Anchor>
                </Anchors>
                <Scripts>
                    <OnVerticalScroll>
                        FauxScrollFrame_OnVerticalScroll(arg1, 24, PoweredAuction_UpdateItemList)
                    </OnVerticalScroll>
                </Scripts>
            </ScrollFrame>

            <Frame name="$parentItemList" enableMouse="true">
                <Size>
                    <AbsDimension x="448" y="370"/>
                </Size>
                <Anchors>
                    <Anchor point="TOPLEFT" relativeTo="$parent" relativePoint="TOPLEFT">
                        <Offset>
                            <AbsDimension x="10" y="-93"/>
                        </Offset>
                    </Anchor>
                </Anchors>
            </Frame>
        </Frames>

        <Scripts>
            <OnLoad>
                this:RegisterForDrag("LeftButton")
            </OnLoad>
            <OnDragStart>
                this:StartMoving()
            </OnDragStart>
            <OnDragStop>
                this:StopMovingOrSizing()
            </OnDragStop>
            <OnShow>
                PlaySound("igMainMenuOpen")
                PoweredAuction_RefreshItemList()
            </OnShow>
            <OnHide>
                PlaySound("igMainMenuClose")
            </OnHide>
        </Scripts>
    </Frame>

    <Frame name="PoweredAuctionEventFrame" hidden="true">
        <Scripts>
            <OnLoad>
                this:RegisterEvent("VARIABLES_LOADED")
                this:RegisterEvent("AUCTION_HOUSE_SHOW")
                this:RegisterEvent("AUCTION_HOUSE_CLOSED")
                this:RegisterEvent("AUCTION_ITEM_LIST_UPDATE")
            </OnLoad>
            <OnEvent>
                PoweredAuction_OnEvent(event)
            </OnEvent>
        </Scripts>
    </Frame>

    <Script file="UI.lua"/>
    <Script file="Minimap.lua"/>

</Ui>
